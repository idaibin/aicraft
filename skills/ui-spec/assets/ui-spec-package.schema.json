{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:idaibin:skills:schemas:ui-spec-package:v2",
  "title": "Repository UI specification package v2",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "text": {"type": "string", "minLength": 1},
    "revision": {"oneOf": [{"type": "integer", "minimum": 1}, {"type": "string", "minLength": 1}]},
    "textList": {"type": "array", "items": {"$ref": "#/$defs/text"}},
    "nonEmptyTextList": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
    "visualSource": {"type": "object", "additionalProperties": false, "required": ["id", "revision", "status", "source", "rights_status", "use", "ignore"], "properties": {"id": {"$ref": "#/$defs/text"}, "revision": {"$ref": "#/$defs/revision"}, "status": {"enum": ["selected", "accepted"]}, "source": {"$ref": "#/$defs/text"}, "rights_status": {"$ref": "#/$defs/text"}, "use": {"$ref": "#/$defs/nonEmptyTextList"}, "ignore": {"$ref": "#/$defs/nonEmptyTextList"}}},
    "output": {"type": "object", "additionalProperties": false, "required": ["root", "path", "sha256"], "properties": {"root": {"enum": ["task-local", "durable-shared"]}, "path": {"$ref": "#/$defs/text"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "approval_ref": {"$ref": "#/$defs/text"}}},
    "promotionApproval": {"type": "object", "additionalProperties": false, "required": ["id", "status", "sanitized", "output", "root", "path", "sha256"], "properties": {"id": {"$ref": "#/$defs/text"}, "status": {"enum": ["approved", "pending", "rejected"]}, "sanitized": {"type": "boolean"}, "output": {"$ref": "#/$defs/text"}, "root": {"const": "durable-shared"}, "path": {"$ref": "#/$defs/text"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}
  },
  "required": ["profile.yaml", "references.yaml", "task.yaml", "design-tokens.json", "component-map.json", "evaluation.yaml", "artifact-manifest.yaml"],
  "properties": {
    "profile.yaml": {"type": "object", "additionalProperties": false, "required": ["version", "revision", "visual_source", "product", "principles", "layout", "surface", "typography", "density", "preferred_patterns", "restricted_patterns", "required_states", "implementation", "avoid"], "properties": {"version": {"const": 2}, "revision": {"$ref": "#/$defs/revision"}, "visual_source": {"$ref": "#/$defs/visualSource"}, "product": {"type": "object"}, "principles": {"$ref": "#/$defs/textList"}, "layout": {"type": "object"}, "surface": {"type": "object"}, "typography": {"type": "object"}, "density": {"$ref": "#/$defs/text"}, "preferred_patterns": {"$ref": "#/$defs/textList"}, "restricted_patterns": {"$ref": "#/$defs/textList"}, "required_states": {"$ref": "#/$defs/textList"}, "implementation": {"type": "object"}, "avoid": {"$ref": "#/$defs/textList"}, "durable_shared": {"type": "object", "additionalProperties": false, "required": ["root"], "properties": {"root": {"$ref": "#/$defs/text"}}}}},
    "references.yaml": {"type": "object", "additionalProperties": false, "required": ["version", "revision", "references"], "properties": {"version": {"const": 2}, "revision": {"$ref": "#/$defs/revision"}, "references": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "source", "rights_status", "local_copy_allowed", "use", "ignore"], "properties": {"id": {"$ref": "#/$defs/text"}, "source": {"$ref": "#/$defs/text"}, "rights_status": {"$ref": "#/$defs/text"}, "local_copy_allowed": {"type": "boolean"}, "use": {"$ref": "#/$defs/nonEmptyTextList"}, "ignore": {"$ref": "#/$defs/nonEmptyTextList"}}}}}},
    "task.yaml": {"type": "object", "additionalProperties": false, "required": ["version", "revision", "visual_source", "task", "scope", "facts", "references", "required_states", "validation", "acceptance", "budget", "recovery"], "properties": {"version": {"const": 2}, "revision": {"$ref": "#/$defs/revision"}, "visual_source": {"$ref": "#/$defs/visualSource"}, "task": {"type": "object", "additionalProperties": false, "required": ["id", "project", "surface", "goal"], "properties": {"id": {"$ref": "#/$defs/text"}, "project": {"$ref": "#/$defs/text"}, "surface": {"$ref": "#/$defs/text"}, "goal": {"$ref": "#/$defs/text"}}}, "scope": {"type": "object", "additionalProperties": false, "required": ["include", "exclude"], "properties": {"include": {"$ref": "#/$defs/textList"}, "exclude": {"$ref": "#/$defs/nonEmptyTextList"}}}, "facts": {"type": "object", "additionalProperties": false, "required": ["available", "unavailable"], "properties": {"available": {"$ref": "#/$defs/textList"}, "unavailable": {"$ref": "#/$defs/nonEmptyTextList"}}}, "references": {"$ref": "#/$defs/textList"}, "required_states": {"$ref": "#/$defs/textList"}, "validation": {"type": "object"}, "acceptance": {"$ref": "#/$defs/textList"}, "budget": {"type": "object"}, "recovery": {"type": "object"}}},
    "design-tokens.json": {"type": "object", "additionalProperties": false, "required": ["version", "revision", "source", "layout", "color", "typography", "surface", "motion"], "properties": {"version": {"const": 2}, "revision": {"$ref": "#/$defs/revision"}, "source": {"$ref": "#/$defs/text"}, "layout": {"type": "object"}, "color": {"type": "object"}, "typography": {"type": "object"}, "surface": {"type": "object"}, "motion": {"type": "object"}}},
    "component-map.json": {"type": "object", "additionalProperties": false, "required": ["version", "revision", "components"], "properties": {"version": {"const": 2}, "revision": {"$ref": "#/$defs/revision"}, "components": {"type": "object", "additionalProperties": {"type": "object", "additionalProperties": false, "required": ["decision", "source", "reason"], "properties": {"decision": {"enum": ["reuse", "adapt", "create"]}, "source": {"$ref": "#/$defs/text"}, "reason": {"$ref": "#/$defs/text"}}}}}},
    "evaluation.yaml": {"type": "object", "additionalProperties": false, "required": ["version", "revision", "status", "deterministic", "hard_blockers", "scores", "total", "decision", "reviewer", "gaps", "promotion_approvals"], "properties": {"version": {"const": 2}, "revision": {"$ref": "#/$defs/revision"}, "status": {"$ref": "#/$defs/text"}, "deterministic": {"type": "object"}, "hard_blockers": {"$ref": "#/$defs/textList"}, "scores": {"type": "object"}, "total": {"type": "number"}, "decision": {"enum": ["pending", "accepted", "rejected"]}, "reviewer": {"$ref": "#/$defs/text"}, "gaps": {"$ref": "#/$defs/textList"}, "promotion_approvals": {"type": "array", "items": {"$ref": "#/$defs/promotionApproval"}}}},
    "artifact-manifest.yaml": {"type": "object", "additionalProperties": false, "required": ["version", "artifact", "source", "inputs", "outputs", "evaluation", "approval", "effort", "rollback"], "properties": {"version": {"const": 2}, "artifact": {"type": "object", "additionalProperties": false, "required": ["id", "revision"], "properties": {"id": {"$ref": "#/$defs/text"}, "revision": {"$ref": "#/$defs/revision"}}}, "source": {"type": "object", "additionalProperties": false, "required": ["repository", "ref", "visual_source_id", "visual_source_revision"], "properties": {"repository": {"$ref": "#/$defs/text"}, "ref": {"$ref": "#/$defs/text"}, "visual_source_id": {"$ref": "#/$defs/text"}, "visual_source_revision": {"$ref": "#/$defs/revision"}}}, "inputs": {"type": "object", "additionalProperties": false, "required": ["profile_revision", "task_revision", "reference_revision", "tokens_revision", "component_map_revision", "evaluation_revision", "rubric_revision"], "properties": {"profile_revision": {"$ref": "#/$defs/revision"}, "task_revision": {"$ref": "#/$defs/revision"}, "reference_revision": {"$ref": "#/$defs/revision"}, "tokens_revision": {"$ref": "#/$defs/revision"}, "component_map_revision": {"$ref": "#/$defs/revision"}, "evaluation_revision": {"$ref": "#/$defs/revision"}, "rubric_revision": {"const": 1}}}, "outputs": {"type": "object", "additionalProperties": false, "required": ["profile", "references", "task", "tokens", "component_map", "evaluation"], "properties": {"profile": {"$ref": "#/$defs/output"}, "references": {"$ref": "#/$defs/output"}, "task": {"$ref": "#/$defs/output"}, "tokens": {"$ref": "#/$defs/output"}, "component_map": {"$ref": "#/$defs/output"}, "evaluation": {"$ref": "#/$defs/output"}}}, "evaluation": {"type": "object", "additionalProperties": false, "required": ["score", "status"], "properties": {"score": {"type": "number"}, "status": {"$ref": "#/$defs/text"}}}, "approval": {"type": "object", "additionalProperties": false, "required": ["approved_by", "approved_at"], "properties": {"approved_by": {"type": ["string", "null"]}, "approved_at": {"type": ["string", "null"]}}}, "effort": {"type": "object", "additionalProperties": false, "required": ["duration_minutes"], "properties": {"duration_minutes": {"type": "integer", "minimum": 0}}}, "rollback": {"type": "object", "additionalProperties": false, "required": ["accepted_revision"], "properties": {"accepted_revision": {"type": ["string", "integer", "null"]}}}}}
  }
}
